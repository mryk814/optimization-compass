{
  "name": "optimization-compass-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest --exclude=e2e/**",
    "parity": "vitest run --config vite.parity.config.ts",
    "typecheck": "tsc --project tsconfig.app.json --noEmit && tsc --project tsconfig.node.json --noEmit",
    "build": "npm run typecheck && vite build",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "npm run build && npm run test:e2e:artifact",
    "test:e2e:artifact": "playwright test",
    "test:e2e:critical": "playwright test --grep @critical --project=chromium-desktop",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
